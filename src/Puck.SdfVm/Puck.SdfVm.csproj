<Project Sdk="Microsoft.NET.Sdk">
    <!--
        The signed-distance-function engine: the instruction ISA, the program representation, the fluent
        authoring builder, the single-source HLSL shaders (the SDF VM interpreter sdf-vm.hlsli plus the
        view/composite/fullscreen stages), and the GPU host that runs the VM — SdfWorldEngine (the
        device-explicit pipeline core: beam cull → per-view render → split-screen composite over a viewport
        table of cameras + regions) and SdfEngineNode (the host-model IRenderNode that renders the world into
        its own offscreen surface for a host to composite). Fully backend-neutral: only the IGpuCompute*
        seams from Puck.Abstractions, never Vulkan or DirectX types. The C# and the shaders are halves of
        one engine and must stay in sync.
    -->
    <PropertyGroup>
        <!-- The DirectX Shader Compiler (ships with the Vulkan SDK and the Windows SDK) compiles the single
             HLSL source to both SPIR-V (Vulkan) and DXIL (DirectX). Override with /p:DxcCommand="path\to\dxc". -->
        <DxcCommand>dxc</DxcCommand>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\Puck.Abstractions\Puck.Abstractions.csproj" />
        <ProjectReference Include="..\Puck.Assets\Puck.Assets.csproj" />
        <ProjectReference Include="..\Puck.Cameras\Puck.Cameras.csproj" />
        <ProjectReference Include="..\Puck.Capture\Puck.Capture.csproj" />
        <ProjectReference Include="..\Puck.Compositing\Puck.Compositing.csproj" />
        <ProjectReference Include="..\Puck.Hosting\Puck.Hosting.csproj" />
        <ProjectReference Include="..\Puck.Shaders\Puck.Shaders.csproj" />
    </ItemGroup>

    <ItemGroup>
        <!-- The committed bytecode: SPIR-V for the Vulkan SDF renderer, DXIL for the DirectX SDF producer. Declared
             ONCE as ShaderBytecode (the ValidateShaderBytecodeSources staleness guard batches over it) and shipped by
             deriving Content from it, so a new bytecode glob can never be shipped without also being guarded. -->
        <ShaderBytecode Include="Assets\Shaders\**\*.spv" />
        <ShaderBytecode Include="Assets\Shaders\**\*.dxil" />
        <Content Include="@(ShaderBytecode)" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

    <ItemGroup>
        <VertexShaderSource Include="Assets\Shaders\**\*.vert.hlsl" />
        <FragmentShaderSource Include="Assets\Shaders\**\*.frag.hlsl" />
        <!-- The ray-query kernels (*.rq.comp.hlsl) need Shader Model 6.5 (inline RayQuery) and the vulkan1.2 SPIR-V
             target, so they have their own rule below; EXCLUDE them from the cs_6_0 compute batch. They compile to
             BOTH SPIR-V (Vulkan) and DXIL (Direct3D 12 DXR 1.1) — inline ray tracing is expressible in both. -->
        <ComputeShaderSource Include="Assets\Shaders\**\*.comp.hlsl" Exclude="Assets\Shaders\**\*.rq.comp.hlsl" />
        <RayQueryComputeShaderSource Include="Assets\Shaders\**\*.rq.comp.hlsl" />
        <ShaderInclude Include="Assets\Shaders\**\*.hlsli" />
    </ItemGroup>

    <Target Name="ValidateShaderBytecodeSources" BeforeTargets="PrepareForBuild">
        <Error
            Condition="'%(ShaderBytecode.Identity)' != '' and !Exists('%(ShaderBytecode.RootDir)%(ShaderBytecode.Directory)%(ShaderBytecode.Filename).hlsl')"
            Text="Shader bytecode '%(ShaderBytecode.Identity)' has no matching HLSL source '%(ShaderBytecode.Filename).hlsl'. Remove stale bytecode or add the source."
        />
    </Target>

    <!-- Compile each *.vert.hlsl / *.frag.hlsl to BOTH SPIR-V (Vulkan; entry renamed to "main") and DXIL
         (DirectX). DXC resolves #include relative to the source directory. The vk:: binding/push-constant
         attributes are SPIR-V-only, so the DXIL pass suppresses the "attribute ignored" warnings. -->
    <Target
        BeforeTargets="PrepareForBuild"
        Inputs="@(VertexShaderSource);@(FragmentShaderSource);@(ComputeShaderSource);@(RayQueryComputeShaderSource);@(ShaderInclude);$(MSBuildProjectFullPath)"
        Name="CompileShaders"
        Outputs="@(VertexShaderSource -> '%(RootDir)%(Directory)%(Filename).spv');@(VertexShaderSource -> '%(RootDir)%(Directory)%(Filename).dxil');@(FragmentShaderSource -> '%(RootDir)%(Directory)%(Filename).spv');@(FragmentShaderSource -> '%(RootDir)%(Directory)%(Filename).dxil');@(ComputeShaderSource -> '%(RootDir)%(Directory)%(Filename).spv');@(ComputeShaderSource -> '%(RootDir)%(Directory)%(Filename).dxil');@(RayQueryComputeShaderSource -> '%(RootDir)%(Directory)%(Filename).spv');@(RayQueryComputeShaderSource -> '%(RootDir)%(Directory)%(Filename).dxil')"
    >
        <Exec
            Command="&quot;$(DxcCommand)&quot; --version"
            ConsoleToMSBuild="true"
            IgnoreExitCode="true"
            StandardErrorImportance="High"
            StandardOutputImportance="Low"
        >
            <Output
                PropertyName="DxcProbeExitCode"
                TaskParameter="ExitCode"
            />
        </Exec>
        <Error
            Condition="'$(DxcProbeExitCode)' != '0'"
            Text="Puck.SdfVm shader compilation requires '$(DxcCommand)' (the DirectX Shader Compiler) to run. Install the Vulkan SDK or Windows SDK, or pass /p:DxcCommand=&quot;path\to\dxc&quot;."
        />
        <!-- The per-item-type Condition guards (FullPath != '') keep a partial incremental build robust: when
             only one shader stage changed, MSBuild runs the target with the other stage's batch empty, and an
             unguarded Exec would invoke dxc with no input file. -->
        <Exec Condition="'$(DxcProbeExitCode)' == '0' and '%(VertexShaderSource.FullPath)' != ''" Command="&quot;$(DxcCommand)&quot; -spirv -fspv-target-env=vulkan1.0 -fspv-entrypoint-name=main -T vs_6_0 -E VSMain -Fo &quot;%(VertexShaderSource.RootDir)%(VertexShaderSource.Directory)%(VertexShaderSource.Filename).spv&quot; &quot;%(VertexShaderSource.FullPath)&quot;" />
        <Exec Condition="'$(DxcProbeExitCode)' == '0' and '%(VertexShaderSource.FullPath)' != ''" Command="&quot;$(DxcCommand)&quot; -Wno-ignored-attributes -T vs_6_0 -E VSMain -Fo &quot;%(VertexShaderSource.RootDir)%(VertexShaderSource.Directory)%(VertexShaderSource.Filename).dxil&quot; &quot;%(VertexShaderSource.FullPath)&quot;" />
        <Exec Condition="'$(DxcProbeExitCode)' == '0' and '%(FragmentShaderSource.FullPath)' != ''" Command="&quot;$(DxcCommand)&quot; -spirv -fspv-target-env=vulkan1.0 -fspv-entrypoint-name=main -T ps_6_0 -E PSMain -Fo &quot;%(FragmentShaderSource.RootDir)%(FragmentShaderSource.Directory)%(FragmentShaderSource.Filename).spv&quot; &quot;%(FragmentShaderSource.FullPath)&quot;" />
        <Exec Condition="'$(DxcProbeExitCode)' == '0' and '%(FragmentShaderSource.FullPath)' != ''" Command="&quot;$(DxcCommand)&quot; -Wno-ignored-attributes -T ps_6_0 -E PSMain -Fo &quot;%(FragmentShaderSource.RootDir)%(FragmentShaderSource.Directory)%(FragmentShaderSource.Filename).dxil&quot; &quot;%(FragmentShaderSource.FullPath)&quot;" />
        <!-- Compute kernels: SPIR-V (Vulkan; entry renamed to "main") and DXIL (DirectX). The vk:: binding/push-constant
             attributes are SPIR-V-only, so the DXIL pass suppresses the "attribute ignored" warnings; the register()
             slots drive the Direct3D 12 root signature. -->
        <Exec Condition="'$(DxcProbeExitCode)' == '0' and '%(ComputeShaderSource.FullPath)' != ''" Command="&quot;$(DxcCommand)&quot; -spirv -fspv-target-env=vulkan1.0 -fspv-entrypoint-name=main -T cs_6_0 -E CSMain -Fo &quot;%(ComputeShaderSource.RootDir)%(ComputeShaderSource.Directory)%(ComputeShaderSource.Filename).spv&quot; &quot;%(ComputeShaderSource.FullPath)&quot;" />
        <Exec Condition="'$(DxcProbeExitCode)' == '0' and '%(ComputeShaderSource.FullPath)' != ''" Command="&quot;$(DxcCommand)&quot; -Wno-ignored-attributes -T cs_6_0 -E CSMain -Fo &quot;%(ComputeShaderSource.RootDir)%(ComputeShaderSource.Directory)%(ComputeShaderSource.Filename).dxil&quot; &quot;%(ComputeShaderSource.FullPath)&quot;" />
        <!-- Ray-query kernels compile to BOTH backends at Shader Model 6.5: SPIR-V (Vulkan; the vulkan1.2 target env
             enables SPV_KHR_ray_query, entry renamed to "main") and DXIL (Direct3D 12 DXR 1.1 inline ray tracing). The
             vk:: binding/push-constant/image-format attributes are SPIR-V-only, so the DXIL pass suppresses the
             "attribute ignored" warnings; the register() slots drive the Direct3D 12 root signature. -->
        <Exec Condition="'$(DxcProbeExitCode)' == '0' and '%(RayQueryComputeShaderSource.FullPath)' != ''" Command="&quot;$(DxcCommand)&quot; -spirv -fspv-target-env=vulkan1.2 -fspv-entrypoint-name=main -T cs_6_5 -E CSMain -Fo &quot;%(RayQueryComputeShaderSource.RootDir)%(RayQueryComputeShaderSource.Directory)%(RayQueryComputeShaderSource.Filename).spv&quot; &quot;%(RayQueryComputeShaderSource.FullPath)&quot;" />
        <Exec Condition="'$(DxcProbeExitCode)' == '0' and '%(RayQueryComputeShaderSource.FullPath)' != ''" Command="&quot;$(DxcCommand)&quot; -Wno-ignored-attributes -T cs_6_5 -E CSMain -Fo &quot;%(RayQueryComputeShaderSource.RootDir)%(RayQueryComputeShaderSource.Directory)%(RayQueryComputeShaderSource.Filename).dxil&quot; &quot;%(RayQueryComputeShaderSource.FullPath)&quot;" />
    </Target>
</Project>
