<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <GlslcCommand>glslc</GlslcCommand>
        <GlslcOptimization>-O</GlslcOptimization>
        <!-- The SDF VM's interpreter shader (sdf-vm.glsl) lives in Puck.SdfVm; the demo's host shader
             includes it cross-project via this glslc include path. -->
        <SdfVmShaderIncludeDir>$(MSBuildThisFileDirectory)..\Puck.SdfVm\Shaders</SdfVmShaderIncludeDir>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\Puck.Assets\Puck.Assets.csproj" />
        <ProjectReference Include="..\Puck.Commands\Puck.Commands.csproj" />
        <ProjectReference Include="..\Puck.Compositing\Puck.Compositing.csproj" />
        <ProjectReference Include="..\Puck.DirectX\Puck.DirectX.csproj" />
        <ProjectReference Include="..\Puck.Hosting\Puck.Hosting.csproj" />
        <ProjectReference Include="..\Puck.Launcher\Puck.Launcher.csproj" />
        <ProjectReference Include="..\Puck.Platform\Puck.Platform.csproj" />
        <ProjectReference Include="..\Puck.SdfVm\Puck.SdfVm.csproj" />
        <ProjectReference Include="..\Puck.Shaders\Puck.Shaders.csproj" />
        <ProjectReference Include="..\Puck.Vulkan\Puck.Vulkan.csproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Hosting" Version="[10.*, )" />
        <PackageReference Include="System.CommandLine" Version="2.0.9" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="Assets\Shaders\**\*.frag" CopyToOutputDirectory="PreserveNewest" />
        <Content Include="Assets\Shaders\**\*.spv" CopyToOutputDirectory="PreserveNewest" />
        <Content Include="Assets\Shaders\**\*.vert" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

    <ItemDefinitionGroup>
        <ShaderSource>
            <TargetEnv>vulkan1.0</TargetEnv>
        </ShaderSource>
    </ItemDefinitionGroup>

    <ItemGroup>
        <ShaderInclude Include="$(SdfVmShaderIncludeDir)\**\*.glsl" />
        <ShaderSource Include="Assets\Shaders\**\*.frag" />
        <ShaderSource Include="Assets\Shaders\**\*.vert" />
    </ItemGroup>

    <Target
        BeforeTargets="PrepareForBuild"
        Inputs="@(ShaderSource);@(ShaderInclude);$(MSBuildProjectFullPath)"
        Name="CompileShaders"
        Outputs="@(ShaderSource -> '%(RootDir)%(Directory)%(Filename)%(Extension).spv')"
    >
        <Exec
            Command="&quot;$(GlslcCommand)&quot; --version"
            ConsoleToMSBuild="true"
            IgnoreExitCode="true"
            StandardErrorImportance="High"
            StandardOutputImportance="Low"
        >
            <Output
                PropertyName="GlslcProbeExitCode"
                TaskParameter="ExitCode"
            />
        </Exec>
        <Error
            Condition="'$(GlslcProbeExitCode)' != '0'"
            Text="Puck.Demo shader compilation requires '$(GlslcCommand)' to run successfully. Install the Vulkan SDK or pass /p:GlslcCommand=&quot;path\to\glslc&quot;."
        />
        <Exec
            Condition="'$(GlslcProbeExitCode)' == '0'"
            Command="&quot;$(GlslcCommand)&quot; $(GlslcOptimization) -I &quot;$(SdfVmShaderIncludeDir)&quot; --target-env=%(ShaderSource.TargetEnv) &quot;%(ShaderSource.FullPath)&quot; -o &quot;%(ShaderSource.RootDir)%(ShaderSource.Directory)%(ShaderSource.Filename)%(ShaderSource.Extension).spv&quot;"
        />
    </Target>
</Project>
