                "azimuth": 0.0,
                "fieldOfView": 60.0,
                "height": 1.6,
                "radius": 5.2,
                "target": [0.0, 0.1, 0.0]
            },
            "region": [0.0, 0.0, 1.0, 1.0]
        }
    ],
    "graph": { "$type": "world" }
}
