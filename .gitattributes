# Line endings: normalize to LF in the repo, check out native per OS.
* text=auto
*.sh   text eol=lf
*.ps1  text eol=crlf
*.cmd  text eol=crlf
*.slnx text eol=crlf

# Richer diffs.
*.cs diff=csharp
*.c  diff=cpp
*.h  diff=cpp

# Binary artifacts: never diff or EOL-convert.
*.png  binary
*.dll  binary
*.so   binary
*.lib  binary
*.pdb  binary
*.spv  binary linguist-generated
*.dxil binary linguist-generated

# Vendored / prebuilt third-party code: keep off code metrics.
lib/**                                  linguist-vendored
experimental/Puck.BareMetal/lwip/**     linguist-vendored
experimental/Puck.BareMetal/mbedtls/**  linguist-vendored
experimental/Puck.BareMetal/mimalloc/** linguist-vendored
