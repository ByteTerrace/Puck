<!--
    Shared build targets for a Puck.BareMetal UEFI application.

    Companion to Puck.BareMetal.Efi.props. Like the hosted Puck.BareMetal.targets it trims the
    reference set and host config, builds the freestanding native glue, and strips the full
    NativeAOT runtime out of the link — but for a UEFI image: it compiles the EFI native glue
    (no mimalloc, no CRT, no kernel32), links NO OS import libraries at all, and sets the PE
    subsystem to EFI_APPLICATION with relocations preserved (the firmware relocates the image).
-->
<Project>

    <!-- Drop every reference assembly except the core library (same as the hosted build). -->
    <Target Name="TrimReferencesToPuck"
            BeforeTargets="BeforeCompile"
            AfterTargets="FindReferenceAssembliesForReferences">
        <ItemGroup>
            <ReferencePathWithRefAssemblies Remove="@(ReferencePathWithRefAssemblies)" Condition="'%(FileName)' != 'Puck.Runtime'" />
            <ReferencePath Remove="@(ReferencePath)" Condition="'%(FileName)' != 'Puck.Runtime'" />
        </ItemGroup>
    </Target>

    <!-- Drop AppContext switches that assume the full runtime. -->
    <Target Name="ClearHostConfiguration"
            BeforeTargets="WriteIlcRspFileForCompilation"
            DependsOnTargets="PrepareForILLink">
        <ItemGroup>
            <RuntimeHostConfigurationOption Remove="@(RuntimeHostConfigurationOption)" />
        </ItemGroup>
    </Target>

    <!-- A UEFI image exports nothing. The SDK otherwise defaults $(ExportsFile) to a .def of the
         [RuntimeExport] symbols, feeds it to the ILC (the exportsfile arg) and to the linker
         (/DEF in the LinkNative target) - and an export table is illegal with
         /SUBSYSTEM:EFI_APPLICATION (LNK1294). Clear it before both the ILC rsp is written and
         LinkNative runs, so neither emits exports. EfiEntry is still kept by /ENTRY:EfiEntry. -->
    <Target Name="SuppressEfiExports"
            BeforeTargets="WriteIlcRspFileForCompilation;LinkNative">
        <PropertyGroup>
            <ExportsFile></ExportsFile>
        </PropertyGroup>
    </Target>

    <!--
        Compile the freestanding EFI native glue: the JIT-transition / GC-poll stubs the stock
        ILC does not root, the block-memory intrinsics, and the OS-agnostic runtime helpers — but
        with NO mimalloc and NO kernel32 (fail-fast hangs; allocation, when added, comes from the
        firmware's boot services). compat/native/puck-efi.c is the EFI counterpart of
        puck-rt.c. Built /GS- /O1; requires a VS Developer shell so cl.exe is on PATH.
    -->
    <Target Name="BuildEfiNativeGlue" BeforeTargets="LinkNative">
        <PropertyGroup>
            <!-- Vendored lwIP headers + our lwIP port (lwipopts.h, arch/cc.h). -->
            <_LwipInc>$(MSBuildThisFileDirectory)..\lwip\src\include</_LwipInc>
            <_LwipPort>$(MSBuildThisFileDirectory)..\compat\native\lwip-port</_LwipPort>
            <!-- Vendored mbedTLS headers, its internal library headers, and our freestanding port. -->
            <_MbedInc>$(MSBuildThisFileDirectory)..\mbedtls\include</_MbedInc>
            <_MbedLib>$(MSBuildThisFileDirectory)..\mbedtls\library</_MbedLib>
            <_MbedPort>$(MSBuildThisFileDirectory)..\compat\native\mbedtls-port</_MbedPort>
        </PropertyGroup>
        <ItemGroup>
            <_EfiNativeInput Include="$(MSBuildThisFileDirectory)..\compat\native\puck-efi.c" />
            <_EfiNativeInput Include="$(MSBuildThisFileDirectory)..\compat\native\puck-font.c" />
            <_EfiNativeInput Include="$(MSBuildThisFileDirectory)..\compat\native\puck-netif.c" />
            <!-- Embedded CA trust roots (generated by mbedtls-port/regen-ca-bundle.ps1); just a char array. -->
            <_EfiNativeInput Include="$(MSBuildThisFileDirectory)..\compat\native\puck-ca-bundle.c" />
            <!-- Freestanding shims for the few CRT symbols mbedTLS calls (byteswap, exit); header-free. -->
            <_EfiNativeInput Include="$(MSBuildThisFileDirectory)..\compat\native\puck-tls-shims.c" />
            <!-- Vendored lwIP (IPv4, NO_SYS): feature-disabled files compile to empty objects. -->
            <_EfiNativeInput Include="$(MSBuildThisFileDirectory)..\lwip\src\core\*.c" />
            <_EfiNativeInput Include="$(MSBuildThisFileDirectory)..\lwip\src\core\ipv4\*.c" />
            <_EfiNativeInput Include="$(MSBuildThisFileDirectory)..\lwip\src\netif\ethernet.c" />
        </ItemGroup>
        <MakeDir Directories="$(NativeIntermediateOutputPath)" />
        <Exec Command="cl.exe /nologo /c /GS- /O1 /I&quot;$(_LwipInc)&quot; /I&quot;$(_LwipPort)&quot; /Fo&quot;$(NativeIntermediateOutputPath)%(_EfiNativeInput.Filename).obj&quot; &quot;%(_EfiNativeInput.Identity)&quot;" />
        <ItemGroup>
            <LinkerArg Include="&quot;$(NativeIntermediateOutputPath)%(_EfiNativeInput.Filename).obj&quot;" />
        </ItemGroup>

        <!--
            Vendored mbedTLS 3.6 (TLS 1.2 client) + our engine-agnostic glue (puck-tls-mbedtls.c).
            Compiled with the mbedTLS include paths and our freestanding config selected via
            MBEDTLS_CONFIG_FILE. Disabled modules (PSA, net/timing/fs, TLS server, ...) are guarded by
            #ifdef and compile to empty objects, so the linker drops them. The /D quoting renders as
            /DMBEDTLS_CONFIG_FILE=\"mbedtls_config.h\" so the macro expands to a quoted #include arg.
        -->
        <ItemGroup>
            <_MbedNativeInput Include="$(MSBuildThisFileDirectory)..\compat\native\puck-tls-mbedtls.c" />
            <_MbedNativeInput Include="$(MSBuildThisFileDirectory)..\mbedtls\library\*.c" />
        </ItemGroup>
        <Exec Command="cl.exe /nologo /c /GS- /O1 /I&quot;$(_MbedInc)&quot; /I&quot;$(_MbedLib)&quot; /I&quot;$(_MbedPort)&quot; /DMBEDTLS_CONFIG_FILE=\&quot;puck-mbedtls-config.h\&quot; /Fo&quot;$(NativeIntermediateOutputPath)%(_MbedNativeInput.Filename).obj&quot; &quot;%(_MbedNativeInput.Identity)&quot;" />
        <ItemGroup>
            <LinkerArg Include="&quot;$(NativeIntermediateOutputPath)%(_MbedNativeInput.Filename).obj&quot;" />
        </ItemGroup>

        <!-- The kernel's hand-written assembly: GDT load + the SYSCALL entry trampoline. -->
        <ItemGroup>
            <_EfiAsmInput Include="$(MSBuildThisFileDirectory)..\compat\native\puck-efi-x64.asm" />
        </ItemGroup>
        <Exec Command="ml64.exe /nologo /c /Fo&quot;$(NativeIntermediateOutputPath)%(_EfiAsmInput.Filename).obj&quot; &quot;%(_EfiAsmInput.Identity)&quot;" />
        <ItemGroup>
            <LinkerArg Include="&quot;$(NativeIntermediateOutputPath)%(_EfiAsmInput.Filename).obj&quot;" />
        </ItemGroup>
    </Target>

    <!--
        Minimal UEFI link. Strip the ENTIRE NativeAOT runtime AND every OS import library (a UEFI
        image imports nothing), set the EFI_APPLICATION subsystem, link no default/CRT libraries,
        and keep base relocations (the firmware loads the image at a runtime-chosen base).
    -->
    <Target Name="LinkEfiMinimal" BeforeTargets="LinkNative">
        <ItemGroup>
            <!-- Remove ALL runtime + OS import libs (no kernel32/advapi32 exception this time). -->
            <LinkerArg Remove="@(NativeLibrary->'&quot;%(Identity)&quot;')" />
            <LinkerArg Remove="@(SdkNativeLibrary->'&quot;%(Identity)&quot;')" />

            <!-- /NATVIS targets a PDB; with no debug info it only earns a linker warning. -->
            <LinkerArg Remove="@(LinkerArg)" Condition="$([System.String]::Copy('%(Identity)').StartsWith('/NATVIS'))" />

            <!-- Replace whatever subsystem the SDK chose with EFI_APPLICATION. -->
            <LinkerArg Remove="@(LinkerArg)" Condition="$([System.String]::Copy('%(Identity)').StartsWith('/SUBSYSTEM'))" />

            <!-- A UEFI image exports nothing; the SDK emits a /DEF with an EXPORTS table for the
                 [RuntimeExport] symbols, which EFI_APPLICATION rejects (LNK1294). Drop it — the
                 entry is kept by /ENTRY:EfiEntry and the rest by ordinary references. -->
            <LinkerArg Remove="@(LinkerArg)" Condition="$([System.String]::Copy('%(Identity)').StartsWith('/DEF'))" />
        </ItemGroup>
        <ItemGroup>
            <LinkerArg Include="/SUBSYSTEM:EFI_APPLICATION" />
            <!-- No CRT / default libraries; the glue is freestanding. -->
            <LinkerArg Include="/NODEFAULTLIB" />
            <!-- The firmware relocates the image, so base relocations must be present. -->
            <LinkerArg Include="/FIXED:NO" />
            <!-- Fold near-empty read-only sections into .rdata (same rationale as the hosted build). -->
            <LinkerArg Include="/MERGE:.modules=.rdata" />
            <LinkerArg Include="/MERGE:.pdata=.rdata" />
        </ItemGroup>
    </Target>

</Project>
